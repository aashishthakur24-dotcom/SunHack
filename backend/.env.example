# ============================================================
# DecisionDNA Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Neo4j ───────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=decisiondna123

# ── ChromaDB ────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_DECISIONS=decisions
CHROMA_COLLECTION_SOURCES=sources
CHROMA_COLLECTION_ENTITIES=entities

# ── Redis / Celery ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Slack ───────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# ── Google APIs ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/drive.readonly,https://www.googleapis.com/auth/calendar.readonly

# ── App Settings ────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:3000
SECRET_KEY=super-secret-key-change-in-production

# ── Supabase (Backend) ───────────────────────────────────────
# For server-side operations, prefer service role key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_REDIRECT_URL=http://localhost:5173/dashboard

# ── Agent Tuning ────────────────────────────────────────────
INGESTION_CHUNK_SIZE=512
INGESTION_CHUNK_OVERLAP=64
CONFLICT_THRESHOLD=0.72        # Cosine similarity threshold to flag conflict
CONFIDENCE_MIN=0.60            # Minimum confidence to return results
GRAPH_COMMUNITY_RESOLUTION=1.0 # Louvain resolution for GraphRAG communities
MAX_CONCURRENT_AGENTS=4
